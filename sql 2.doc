<h2>6. Create View</h2>
<h3>Query</h3>
<pre><code class="language-sql">CREATE VIEW EmployeeDetails AS
SELECT e.emp_id,
       e.emp_name,
       e.salary,
       d.dept_name
FROM Employee e
JOIN Department d
ON e.dept_id = d.dept_id;
</code></pre>
<h3>Output</h3>
<pre><code class="language-text">View EmployeeDetails created successfully.
</code></pre>
<hr>
